# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=dopamind
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dopamind

# ─── Backend ──────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string (used by the Node.js backend)
DATABASE_URL=postgresql://dopamind:change-me-strong-password@postgres:5432/dopamind

# REQUIRED – JWT signing secret. Must be at least 32 random characters.
# The backend will refuse to start if this is missing.
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# Token expiry (default: 24h)
JWT_EXPIRES_IN=24h

# REQUIRED – AES-256-GCM key for encrypting stored IMAP/SMTP/CalDAV passwords.
# The backend will refuse to start if this is missing.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# Comma-separated list of allowed CORS origins (no wildcards in production)
CORS_ORIGIN=http://localhost:3000,http://localhost

# Backend port (default: 4000)
PORT=4000

# ─── Frontend ─────────────────────────────────────────────────────────────────

# API base URL used by the React app (must match the backend location)
REACT_APP_API_URL=/api
